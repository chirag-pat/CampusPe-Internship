# .env.example — AI Service Environment Variables
# Tool-04 | Risk Appetite Framework
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in real values in .env
#   NEVER commit .env to GitHub — it is in .gitignore
#
# All variables below are REQUIRED unless marked (optional).

# ── Flask ──────────────────────────────────────────────────────────────────
AI_PORT=5000
FLASK_DEBUG=false            # Set to true for local dev only. Never true in Docker.

# ── Groq AI API ───────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Redis (AI response cache + rate limiter storage) ──────────────────────
# Format: redis://:<password>@<host>:<port>/<db>
# In Docker Compose the host is the service name: redis
REDIS_URL=redis://:yourredispassword@redis:6379/0

# ── ChromaDB (vector store for RAG pipeline) ──────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data   # Mount as a Docker volume in production

# ── Security ──────────────────────────────────────────────────────────────
# Used by sanitisation.py for HMAC-based cache key signing (optional hardening)
SANITISATION_HMAC_SECRET=replace_with_64_random_characters_minimum
